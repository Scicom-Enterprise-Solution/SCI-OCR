# Copy this file to .env and update values as needed

# Optional: command name or full path to the tesseract executable
TESSERACT_CMD=tesseract

# Optional: Tesseract language(s), for example eng or eng+ocrb if OCR-B is installed
TESSERACT_LANG=eng

# Optional: OCR engines to try. Legacy OEMs 0 and 2 require legacy-traineddata.
TESSERACT_OEMS=1

# Optional: default input PDF for local runs
PDF_PATH=samples/passport.pdf

# Optional: output directory
OUTPUT_DIR=output

# Optional: use face hint
#USE_FACE_HINT = False
USE_FACE_HINT=False
