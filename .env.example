# Copy this file to .env and update values as needed

# Optional: terminal logging. Default keeps CLI output concise.
DEBUG=False
LOG_FORMAT=human

# Optional: API server settings for the internal upload/extract service.
API_HOST=127.0.0.1
API_PORT=3000
API_STORAGE_DIR=storage
API_DB_PATH=storage/mrz.sqlite3

# Optional: browser CORS settings for API access from another origin.
# Use * for broad development access, or a comma-separated list like http://localhost:5173,http://127.0.0.1:5500
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=*
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=False

# Optional: OpenAI-compatible LLM endpoint settings for Ollama, vLLM, or hosted providers.
# Examples:
#   Ollama: http://127.0.0.1:11434/v1
#   vLLM:   http://127.0.0.1:8000/v1
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60

# Optional: OCR backend. Supported: tesseract, paddle, auto
OCR_BACKEND=paddle

# Optional: command name or full path to the tesseract executable
TESSERACT_CMD=tesseract

# Optional: Tesseract language(s), for example eng or eng+ocrb if OCR-B is installed
TESSERACT_LANG=ocrb

# Optional: OCR engines to try. Legacy OEMs 0 and 2 require legacy-traineddata.
TESSERACT_OEMS=1

# Optional: PaddleOCR language and device settings when OCR_BACKEND includes paddle.
# Set PADDLEOCR_USE_GPU=True only when paddlepaddle-gpu is installed and Paddle can see a CUDA device.
PADDLEOCR_LANG=en
PADDLEOCR_USE_GPU=True
# Optional: explicit PP-OCRv5 model family overrides.
# Allowed values: blank, mobile, server
# Leave these blank to use PaddleOCR's default PP-OCRv5 model selection.
# Set PADDLEOCR_REC_MODEL_VARIANT=server to A/B the stronger recognizer on hard samples.
PADDLEOCR_DET_MODEL_VARIANT=
PADDLEOCR_REC_MODEL_VARIANT=
# Optional: explicit model-name overrides take precedence over the *_MODEL_VARIANT settings.
# Expected format: exact Paddle model name, for example PP-OCRv5_server_det or PP-OCRv5_server_rec
PADDLEOCR_TEXT_DETECTION_MODEL_NAME=
PADDLEOCR_TEXT_RECOGNITION_MODEL_NAME=
# Optional: path overrides if you want to pin exact local model directories.
# Expected format: filesystem path to a Paddle model directory containing inference files
PADDLEOCR_TEXT_DETECTION_MODEL_DIR=
PADDLEOCR_TEXT_RECOGNITION_MODEL_DIR=
# Optional: recognition score threshold passed through to PaddleOCR.
# Expected format: float from 0.0 to 1.0, for example 0.8
PADDLEOCR_TEXT_REC_SCORE_THRESH=
# Optional: PaddleX/PaddleOCR cache directory. Use a project-relative path for portability.
PADDLE_PDX_CACHE_HOME=.paddlex

# Optional: enable a much smaller OCR search space for faster runs.
# Keep this disabled for accuracy-first MRZ extraction.
FAST_OCR=False
MRZ_VARIANT_WORKERS=4

# Optional: (balanced, exhaustive, fast) Paddle search profile.
# Keep exhaustive for accuracy-first reference verification.
PADDLE_PROFILE=exhaustive

# Optional: use a smaller Paddle-only search profile plus strict early-exit.
# Keep disabled for accuracy-first runs.
PADDLE_FAST=False

# Optional: experimental curved MRZ line rectification after row splitting.
# Supported: off, line1, both.
# Keep off unless you are testing warped or curved MRZ rows.
MRZ_CURVED_LINE_FLATTEN_MODE=off

# Optional: default input PDF for local runs
PDF_PATH=samples/passport.pdf

# Optional: output directory
OUTPUT_DIR=output

# Optional: cap the aligned passport working image before MRZ detection/OCR.
# The longest side will be limited to this many pixels.
ALIGNED_MAX_DIM=1200

# Optional: use face hint
USE_FACE_HINT=False
