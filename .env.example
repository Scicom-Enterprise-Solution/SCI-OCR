# Copy this file to .env and update values as needed

# Optional: terminal logging. Default keeps CLI output concise.
DEBUG=False
LOG_FORMAT=human

# Optional: API server settings for the internal upload/extract service.
API_HOST=127.0.0.1
API_PORT=3000
API_STORAGE_DIR=storage
API_DB_PATH=storage/mrz.sqlite3

# Optional: browser CORS settings for API access from another origin.
# Use * for broad development access, or a comma-separated list like http://localhost:5173,http://127.0.0.1:5500
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=*
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=False

# Optional: OCR backend. Supported: tesseract, paddle, auto
OCR_BACKEND=paddle

# Optional: command name or full path to the tesseract executable
TESSERACT_CMD=tesseract

# Optional: Tesseract language(s), for example eng or eng+ocrb if OCR-B is installed
TESSERACT_LANG=ocrb

# Optional: OCR engines to try. Legacy OEMs 0 and 2 require legacy-traineddata.
TESSERACT_OEMS=1

# Optional: PaddleOCR language and device settings when OCR_BACKEND includes paddle.
# Set PADDLEOCR_USE_GPU=True only when paddlepaddle-gpu is installed and Paddle can see a CUDA device.
PADDLEOCR_LANG=en
PADDLEOCR_USE_GPU=True
# Optional: PaddleX/PaddleOCR cache directory. Use a project-relative path for portability.
PADDLE_PDX_CACHE_HOME=.paddlex

# Optional: enable a much smaller OCR search space for faster runs.
# Keep this disabled for accuracy-first MRZ extraction.
FAST_OCR=False
MRZ_VARIANT_WORKERS=4

# Optional: (balanced,exhaustive,fast) Paddle search profile. balanced is a middle ground between exhaustive and fast.
PADDLE_PROFILE=balanced

# Optional: use a smaller Paddle-only search profile plus strict early-exit.
# Recommended for production speed when OCR_BACKEND=paddle.
PADDLE_FAST=False

# Optional: default input PDF for local runs
PDF_PATH=samples/passport.pdf

# Optional: output directory
OUTPUT_DIR=output

# Optional: cap the aligned passport working image before MRZ detection/OCR.
# The longest side will be limited to this many pixels.
ALIGNED_MAX_DIM=1200

# Optional: use face hint
USE_FACE_HINT=False
